<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Innowise.Music.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Innowise.Music"
    xmlns:view="clr-namespace:Innowise.Music.View"
    Title="Innowise.Music"
    FlyoutBehavior="Disabled">

    <ShellContent
        ContentTemplate="{DataTemplate view:LoginPage}"
        Route="LoginPage"
        FlyoutItemIsVisible="False" />

    <TabBar>
        <Tab Title="Home" Icon="home_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate view:HomePage}" Route="HomePage" />
        </Tab>
        <Tab Title="Search" Icon="search_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate view:SearchPage}" Route="SearchPage" />
        </Tab>
        <Tab Title="Library" Icon="library_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate view:LibraryPage}" Route="LibraryPage" />
        </Tab>
        <Tab Title="Events" Icon="events_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate view:EventsPage}" Route="EventsPage" />
        </Tab>
    </TabBar>

</Shell>
