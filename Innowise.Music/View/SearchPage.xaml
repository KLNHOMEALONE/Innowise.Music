<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Innowise.Music.ViewModel"
             xmlns:controls="clr-namespace:Innowise.Music.Controls"
             xmlns:converters="clr-namespace:Innowise.Music.Converters"
             x:Class="Innowise.Music.View.SearchPage"
             x:DataType="vm:SearchPageViewModel"
             BackgroundColor="{StaticResource Gray950}"
             Shell.NavBarIsVisible="False"
             Title="Search">

    <ContentPage.Resources>
        <converters:BoolToFavoriteIconConverter x:Key="BoolToFavoriteIconConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <VerticalStackLayout Grid.Row="0" Spacing="20" Padding="20">
            <!-- Search Bar -->
            <Border BackgroundColor="{StaticResource InputBackgroundColor}" StrokeShape="RoundRectangle 8" HeightRequest="50" Padding="15,0" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" Margin="0,0,10,0" />
                    <Entry Grid.Column="1" 
                           Text="{Binding SearchQuery}" 
                           Placeholder="What do you want to listen to?" 
                           PlaceholderColor="Gray"
                           TextColor="White"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Search Results -->
            <CollectionView ItemsSource="{Binding SearchResults}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultItem">
                        <Grid ColumnDefinitions="50, *, Auto" Padding="0,10" ColumnSpacing="15">
                            <Image Grid.Column="0" Source="{Binding ImageUrl}" Aspect="AspectFill" WidthRequest="50" HeightRequest="50" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Title}" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding Subtitle}" TextColor="Gray" FontSize="14" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="20">
                                <Image Source="{Binding IsFavorited, Converter={StaticResource BoolToFavoriteIconConverter}}" WidthRequest="24" HeightRequest="24" />
                                <Label Text="⋮" TextColor="White" FontSize="24" />
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
        
        <controls:MiniPlayerControl Grid.Row="1" />
    </Grid>
</ContentPage>
