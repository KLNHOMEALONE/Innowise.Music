<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Innowise.Music.ViewModel"
             xmlns:controls="clr-namespace:Innowise.Music.Controls"
             x:Class="Innowise.Music.View.EventsPage"
             x:DataType="vm:EventsPageViewModel"
             BackgroundColor="{StaticResource Gray950}"
             Shell.NavBarIsVisible="False"
             Title="Events">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Tabs -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Padding="20,10" ColumnSpacing="10">
            <VerticalStackLayout Grid.Column="0" Spacing="5">
                <Label Text="Map" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowMapViewCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2" Color="#D90429" IsVisible="{Binding IsMapViewVisible}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="5">
                <Label Text="List" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowListViewCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <BoxView HeightRequest="2" Color="#D90429" IsVisible="{Binding IsListViewVisible}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Map View -->
        <Border Grid.Row="1" IsVisible="{Binding IsMapViewVisible}" BackgroundColor="{StaticResource Gray900}" Margin="20,0" StrokeShape="RoundRectangle 12" StrokeThickness="0">
            <Label Text="Map Placeholder" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>

        <!-- List View -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding EventGroups}" IsVisible="{Binding IsListViewVisible}" IsGrouped="True">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:EventGroup">
                    <Label Text="{Binding Month}" TextColor="White" FontSize="22" FontAttributes="Bold" Padding="20,20,20,10" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:MusicEvent">
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource InputBackgroundColor}" Margin="20,0,20,15" Padding="15" StrokeThickness="0">
                        <Grid ColumnDefinitions="100, *">
                            <Image Grid.Column="0" Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="100" />
                            <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Date}" TextColor="White" FontSize="12" />
                                <Label Text="{Binding Title}" TextColor="White" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Venue}" TextColor="Gray" FontSize="14" />
                                <Button Text="Get tickets" BackgroundColor="#D90429" TextColor="White" CornerRadius="12" HeightRequest="25" HorizontalOptions="Fill" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <controls:MiniPlayerControl Grid.Row="2" />
    </Grid>
</ContentPage>
