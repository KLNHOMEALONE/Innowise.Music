<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Innowise.Music.ViewModel"
             xmlns:controls="clr-namespace:Innowise.Music.Controls"
             x:Class="Innowise.Music.View.LibraryPage"
             x:DataType="vm:LibraryPageViewModel"
             BackgroundColor="{StaticResource PageBackgroundColor}"
             Shell.NavBarIsVisible="False"
             Title="Library">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20">
                
                <!-- Header -->
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="#D90429" StrokeThickness="0">
                        <Label Text="J" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="Black" FontSize="16" />
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="{StaticResource InputBackgroundColor}" StrokeThickness="0" StrokeShape="RoundRectangle 4" HeightRequest="40">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="🔍" TextColor="Gray" VerticalOptions="Center" Margin="10,0,5,0" />
                            <Entry Grid.Column="1" Placeholder="Find in your library" PlaceholderColor="Gray" TextColor="White" BackgroundColor="Transparent" FontSize="14" VerticalOptions="Center" Margin="0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18" BackgroundColor="Transparent" Stroke="White" StrokeThickness="1.5">
                        <Label Text="+" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="20" Margin="0,-2,0,0" />
                    </Border>
                </Grid>

                <!-- Filter Chips -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,20,0,0">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding FilterChips}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border BackgroundColor="{StaticResource InputBackgroundColor}" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="16,8">
                                    <Label Text="{Binding .}" TextColor="White" FontSize="14" FontAttributes="Bold" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Separator Line -->
                <BoxView HeightRequest="1" Color="{StaticResource Gray900}" Margin="-20,20,-20,20" />

                <!-- Sort/View Toggle -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                         <Label Text="⇅" TextColor="White" FontSize="18" FontAttributes="Bold" />
                         <Label Text="Recents" TextColor="White" FontSize="18" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                    <Label Grid.Column="1" Text="▤" TextColor="White" FontSize="22" VerticalOptions="Center" />
                </Grid>

                <!-- Library Grid -->
                <FlexLayout BindableLayout.ItemsSource="{Binding LibraryItems}"
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            AlignItems="Start">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryItem">
                            <Grid WidthRequest="110" HeightRequest="165" Margin="0,0,0,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="110" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" WidthRequest="110" HeightRequest="110" 
                                        BackgroundColor="{Binding IconBackgroundColor}"
                                        StrokeThickness="0"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                         <RoundRectangle CornerRadius="{Binding ItemCornerRadius}" />
                                    </Border.StrokeShape>
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                        <Label Text="{Binding Icon}" TextColor="White" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasIcon}" />
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Grid.Row="1" Spacing="2" Margin="0,8,0,0">
                                    <Label Text="{Binding DisplayTitle}" TextColor="White" FontSize="13" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Subtitle}" TextColor="Gray" FontSize="12" MaxLines="1" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

            </VerticalStackLayout>
        </ScrollView>
        
        <controls:MiniPlayerControl Grid.Row="1" />
    </Grid>
</ContentPage>
